# ============================================
.env
.env.local
.env.*.local
.env.*
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets/
*.kubeconfig

# ============================================
# Documentation
# ============================================
README.md
docs/
*.md
# Note: SQL files (*.sql) are NOT excluded - needed for DB init

