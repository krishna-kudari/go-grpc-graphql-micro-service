# Air (Hot Reload) - Dev Tool
# ============================================
.air.toml
**/.air.toml

# ============================================
# Docker Files
# ============================================
# Exclude Docker files themselves (not needed in image)
docker-compose.yml
docker-compose.dev.yml
docker-compose.override.yml
*.dockerfile
.dockerignore
Dockerfile*
docker-compose*.yml

# ============================================
# Kubernetes Manifests
# ============================================
k8s/
kubernetes/
*.yaml
*.yml
# Note: Keep SQL migration files (up.sql) - they're needed for DB initialization

